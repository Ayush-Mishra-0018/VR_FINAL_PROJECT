all_images = list(df["image_rel"].unique())

def crop_all(model, rel_paths, save_dir, conf=0.25):
    os.makedirs(save_dir, exist_ok=True)

    for rel in tqdm(rel_paths, desc="Cropping products"):
        src = os.path.join(IMG_ROOT, rel)

        if not os.path.exists(src):
            continue

        img = cv2.imread(src)
        if img is None:
            continue

        pred = model.predict(
            source=img,
            conf=conf,
            verbose=False,
            device=0
        )[0]

        if len(pred.boxes) == 0:
            continue

        confs = pred.boxes.conf.cpu().numpy()
        idx = int(np.argmax(confs))

        box = pred.boxes.xyxy.cpu().numpy()[idx]
        x1, y1, x2, y2 = map(int, box)

        x1 = max(0, x1)
        y1 = max(0, y1)
        x2 = min(img.shape[1], x2)
        y2 = min(img.shape[0], y2)

        crop = img[y1:y2, x1:x2]
        if crop.size == 0:
            continue

        name = rel.replace("/", "__")
        save_path = os.path.join(save_dir, name)
        cv2.imwrite(save_path, crop)

