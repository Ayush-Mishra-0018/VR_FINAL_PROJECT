# =========================
# 7. BOX CONVERSION
# =========================
def xyxy_to_yolo(x1, y1, x2, y2, w, h):
    xc = ((x1 + x2) / 2) / w
    yc = ((y1 + y2) / 2) / h
    bw = (x2 - x1) / w
    bh = (y2 - y1) / h
    return xc, yc, bw, bh

# =========================
# 8. BUILD YOLO DATASET
# =========================
def build_split(split_df, img_dir, lbl_dir):
    skipped = 0

    for _, row in tqdm(split_df.iterrows(), total=len(split_df), desc=f"Creating {img_dir}"):

        rel = row["image_rel"]
        src = os.path.join(IMG_ROOT, rel)

        if not os.path.exists(src):
            skipped += 1
            continue

        img = cv2.imread(src)
        if img is None:
            skipped += 1
            continue

        h, w = img.shape[:2]

        x1, y1, x2, y2 = int(row["x1"]), int(row["y1"]), int(row["x2"]), int(row["y2"])
        cls_id = int(row["class_id"])

        xc, yc, bw, bh = xyxy_to_yolo(x1, y1, x2, y2, w, h)

        safe_name = rel.replace("/", "__")
        img_dst = os.path.join(img_dir, safe_name)
        lbl_dst = os.path.join(lbl_dir, Path(safe_name).stem + ".txt")

        shutil.copy(src, img_dst)

        with open(lbl_dst, "w") as f:
            f.write(f"{cls_id} {xc:.6f} {yc:.6f} {bw:.6f} {bh:.6f}\n")

    print("Skipped:", skipped)

