# 5. PARSE BBOX FILE
# =========================
def parse_bbox(txt_path):
    rows = []

    with open(txt_path, "r") as f:
        lines = f.readlines()[2:]   # skip header lines

    for line in tqdm(lines, desc="Parsing annotations"):
        line = line.strip()
        if not line:
            continue

        parts = line.split()

        img_rel = parts[0]
        cls_raw = int(parts[1])   # 1,2,3
        pose    = int(parts[2])
        x1, y1, x2, y2 = map(int, parts[3:7])

        rows.append([img_rel, cls_raw, pose, x1, y1, x2, y2])

    df = pd.DataFrame(rows, columns=[
        "image_rel", "class_raw", "pose", "x1", "y1", "x2", "y2"
    ])
    return df

df = parse_bbox(BBOX_FILE)

# raw classes: 1 upper, 2 lower, 3 full
